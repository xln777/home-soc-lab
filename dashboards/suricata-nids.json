    },
    {
      "datasource": { "type": "loki", "uid": "loki" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 50 }
            ]
          },
          "custom": { "displayMode": "color-background" }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "src_ip" },
            "properties": [{ "id": "custom.width", "value": 160 }]
          }
        ]
      },
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 15 },
      "id": 20,
      "options": {
        "footer": { "show": false },
        "showHeader": true,
        "sortBy": [{ "desc": true, "displayName": "Anzahl" }]
      },
      "title": "Top Quell-IPs (Alerts)",
      "type": "table",
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "topk(15, sum by (src_ip) (count_over_time({job=\"suricata\"} | json | event_type=\"alert\" | src_ip != \"\" [$__range])))",
          "legendFormat": "{{src_ip}}",
          "instant": true,
          "refId": "A"
        }
      ],
      "transformations": [
        { "id": "labelsToFields", "options": { "valueLabel": "src_ip" } },
        { "id": "organize", "options": { "renameByName": { "Value": "Anzahl", "src_ip": "Quell-IP" } } }
      ]
    },
